# Per-rig hardware identifiers for the gripper recording setup.
# Sourced by start_recording_interface_gripper.sh and passed to
# gripper_launch_single_force.launch as roslaunch arg overrides.
#
# EDIT EVERY VALUE FOR YOUR HARDWARE. How to find them:
#   DIGIT ids     : printed on each GelSight DIGIT sensor
#   USB serials   : `ls /dev/serial/by-id/` (the FTDI/Dynamixel and the Arduino entries)
#   MIN/MAX_TICKS : from the gripper motor calibration (assembly step)
#   ETHERCAT_BUS  : `ip link` (the NIC wired to the Bota F/T sensor)

# GelSight DIGIT tactile sensor ids
DIGIT_LEFT_ID=D21235
DIGIT_RIGHT_ID=D21228

# Dynamixel gripper motor (FTDI USB-serial adapter)
DXL_PORT=/dev/serial/by-id/usb-FTDI_USB__-__Serial_Converter_FT89FCUV-if00-port0

# Load-cell Arduino (rosserial)
LOADCELL_PORT=/dev/serial/by-id/usb-Arduino_LLC_Arduino_Nano_Every_1E4CCDEC515346354E202020FF113D46-if00

# Gripper motor open/close tick limits (per-assembled-gripper calibration)
MIN_TICKS=106
MAX_TICKS=197

# Bota / Rokubimini force-torque sensor EtherCAT bus (host NIC)
ETHERCAT_BUS=eth0
